# AI跨境电商系统 - 环境变量配置
# 复制此文件为 .env 并填入实际值

# AI服务
DEEPSEEK_API_KEY=your_deepseek_api_key
CLAUDE_API_KEY=your_claude_api_key
HUNYUAN_API_KEY=your_hunyuan_api_key

# 电商平台API
AMAZON_SELLER_ID=your_seller_id
AMAZON_MWS_AUTH_TOKEN=your_mws_token
AMAZON_SP_API_KEY=your_sp_api_key
SHOPIFY_API_KEY=your_shopify_key
SHOPIFY_STORE_URL=your_store.myshopify.com

# 1688供应商
ALIBABA_1688_COOKIE=your_1688_cookie

# 运营配置
TARGET_MARKETS=US,UK,DE
BUDGET_YUAN=50000
MAX_INITIAL_PRODUCTS=5

# 海外仓
WAREHOUSE_US_ADDRESS=your_us_warehouse_address
WAREHOUSE_US_CONTACT=contact@warehouse.com
