.container{padding:24rpx;background:#F5F9F5;min-height:100vh}
.report-hero{background:linear-gradient(135deg,#4CAF50,#66BB6A);border-radius:20rpx;padding:48rpx 30rpx;text-align:center;color:#fff;margin-bottom:24rpx}
.hero-month{font-size:48rpx;font-weight:700}.hero-label{font-size:28rpx;opacity:.8;margin:8rpx 0}.hero-amount{font-size:60rpx;font-weight:700;margin:8rpx 0}.hero-avg{font-size:24rpx;opacity:.7}
.card{background:#fff;border-radius:16rpx;padding:24rpx;margin-bottom:20rpx}
.section-title{font-size:30rpx;font-weight:600;color:#333;margin-bottom:20rpx}
.advice-text{font-size:28rpx;color:#555;line-height:1.6;margin-top:12rpx}
.breakdown-item{display:flex;justify-content:space-between;align-items:center;padding:16rpx 0;border-bottom:1rpx solid #F5F5F5}
.bd-left{flex:1;margin-right:20rpx}.bd-name{font-size:26rpx;color:#333;margin-bottom:8rpx}
.bd-bar-bg{height:8rpx;background:#F0F0F0;border-radius:4rpx}.bd-bar{height:100%;background:#4CAF50;border-radius:4rpx;transition:width .6s}
.bd-right{text-align:right}.bd-amount{font-size:28rpx;font-weight:600;color:#333}.bd-percent{font-size:22rpx;color:#999}
.vip-banner{background:linear-gradient(135deg,#E8F5E9,#C8E6C9);border-radius:16rpx;padding:24rpx;text-align:center;margin-top:20rpx}
.vip-text{font-size:32rpx;font-weight:600;color:#2E7D32}.vip-desc{font-size:24rpx;color:#666;margin-top:8rpx}
