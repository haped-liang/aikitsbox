.container{padding:24rpx;min-height:100vh;background:#F5F9F5}
.today-hero{background:linear-gradient(135deg,#4CAF50,#66BB6A);border-radius:20rpx;padding:40rpx 30rpx;text-align:center;color:#fff;margin-bottom:24rpx}
.today-label{font-size:28rpx;opacity:.9}.today-amount{font-size:64rpx;font-weight:700;margin:12rpx 0}.today-count{font-size:24rpx;opacity:.8}
.quick-amounts{display:flex;gap:12rpx;margin-bottom:24rpx;flex-wrap:wrap}
.quick-btn{background:#fff;padding:14rpx 28rpx;border-radius:30rpx;font-size:26rpx;color:#333;box-shadow:0 2rpx 8rpx rgba(0,0,0,.05)}
.mode-tabs{display:flex;background:#fff;border-radius:16rpx;margin-bottom:24rpx;overflow:hidden}
.mode-tab{flex:1;text-align:center;padding:24rpx;font-size:28rpx;color:#999;transition:all .3s}
.mode-tab.active{background:#4CAF50;color:#fff;font-weight:600}
.voice-area,.photo-area{background:#fff;border-radius:20rpx;padding:60rpx 30rpx;text-align:center;margin-bottom:24rpx}
.voice-btn{display:flex;flex-direction:column;align-items:center;gap:16rpx}
.voice-btn.recording{animation:pulse 1s infinite}
.voice-icon,.photo-icon{font-size:80rpx}.voice-text{font-size:32rpx;font-weight:600;color:#333}.voice-hint{font-size:24rpx;color:#999}
.photo-btn{display:flex;flex-direction:column;align-items:center;gap:16rpx}.photo-text{font-size:28rpx;color:#333}
.manual-form{padding:20rpx 0}
.amount-row{display:flex;align-items:center;justify-content:center;padding:30rpx 0}.currency{font-size:48rpx;color:#333;margin-right:12rpx}.amount-input{font-size:64rpx;font-weight:700;width:300rpx;text-align:center;border-bottom:3rpx dashed #E0E0E0}
.cat-scroll{white-space:nowrap;padding:16rpx 0;margin-bottom:16rpx}
.cat-chip{display:inline-block;padding:12rpx 24rpx;background:#fff;border-radius:20rpx;margin-right:12rpx;font-size:26rpx;border:2rpx solid transparent}.cat-chip.active{background:rgba(76,175,80,.1);border-color:#4CAF50;color:#4CAF50;font-weight:600}
.note-input{width:100%;height:80rpx;background:#fff;border-radius:12rpx;padding:0 24rpx;margin-bottom:24rpx;box-sizing:border-box}
.btn-save{width:100%;height:88rpx;line-height:88rpx;background:linear-gradient(135deg,#4CAF50,#66BB6A);color:#fff;border-radius:44rpx;font-size:32rpx;font-weight:600}
.ai-confirm-card{background:#fff;border-radius:20rpx;padding:30rpx;text-align:center;margin-bottom:24rpx;border:2rpx solid #4CAF50;box-shadow:0 8rpx 30rpx rgba(76,175,80,.15)}
.ai-confirm-amount{font-size:56rpx;font-weight:700;color:#2C1810;margin:16rpx 0}.ai-confirm-cat{font-size:28rpx;color:#4CAF50}.ai-confirm-note{font-size:24rpx;color:#999;margin-top:8rpx}
.ai-confirm-btns{display:flex;gap:20rpx;margin-top:24rpx}
.ai-confirm-btns button{flex:1;height:72rpx;line-height:72rpx;border-radius:36rpx;font-size:28rpx}
.btn-cancel{background:#F5F5F5;color:#999}.btn-confirm{background:#4CAF50;color:#fff}
.today-list{margin-top:30rpx}
.section-title{font-size:30rpx;font-weight:600;color:#333;margin-bottom:16rpx}
.record-item{display:flex;justify-content:space-between;align-items:center;background:#fff;padding:24rpx;border-radius:12rpx;margin-bottom:12rpx}
.record-cat{font-size:28rpx;color:#333}.record-note{font-size:22rpx;color:#999;margin-top:4rpx}.record-amount{font-size:32rpx;font-weight:600;color:#E53935}.record-time{font-size:22rpx;color:#999;text-align:right}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.05)}}
