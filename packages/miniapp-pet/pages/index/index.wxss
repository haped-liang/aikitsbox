.container{padding:24rpx;background:#FFF9F0;min-height:100vh}
.hero{text-align:center;padding:30rpx 0 20rpx}.hero-icon{font-size:64rpx}.hero-title{font-size:40rpx;font-weight:700;color:#E65100;margin:8rpx 0}.hero-sub{font-size:24rpx;color:#8D6E63}.quota{display:inline-block;background:rgba(255,152,0,.12);color:#E65100;padding:8rpx 24rpx;border-radius:20rpx;font-size:22rpx;margin-top:16rpx}.q-num{font-size:30rpx;font-weight:700}
.card{background:#fff;border-radius:20rpx;padding:24rpx;margin-bottom:20rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.04)}
.step-title{font-size:28rpx;font-weight:600;color:#333;margin-bottom:16rpx}
.pet-grid{display:flex;flex-wrap:wrap;gap:12rpx}.pet-chip{padding:16rpx 28rpx;background:#FFF3E0;border-radius:30rpx;font-size:28rpx;border:2rpx solid transparent}.pet-chip:active{background:#FFE0B2;border-color:#FF9800}
.info-row{display:flex;gap:12rpx}.info-input{flex:1;height:70rpx;background:#FFF9F0;border-radius:12rpx;padding:0 16rpx;font-size:26rpx;text-align:center}
.symptom-group{margin-bottom:20rpx}.group-name{font-size:26rpx;color:#8D6E63;margin-bottom:10rpx}.symptom-chips{display:flex;flex-wrap:wrap;gap:10rpx}
.s-chip{padding:10rpx 20rpx;background:#F5F5F5;border-radius:20rpx;font-size:24rpx;color:#666;border:2rpx solid transparent}.s-chip.active{background:rgba(255,152,0,.1);border-color:#FF9800;color:#E65100;font-weight:600}
.duration-row{display:flex;gap:10rpx;flex-wrap:wrap;margin-bottom:20rpx}.d-chip{padding:10rpx 20rpx;background:#F5F5F5;border-radius:20rpx;font-size:24rpx}.d-chip.active{background:rgba(255,152,0,.1);border-color:#FF9800;color:#E65100;font-weight:600}
.extra-input{width:100%;height:120rpx;background:#FFF9F0;border-radius:12rpx;padding:16rpx;font-size:26rpx;margin-bottom:24rpx;box-sizing:border-box}
.step-btns{display:flex;gap:16rpx}.btn-back{flex:1;height:80rpx;line-height:80rpx;background:#F5F5F5;border-radius:40rpx;font-size:28rpx;color:#666}.btn-go{flex:2;height:80rpx;line-height:80rpx;background:linear-gradient(135deg,#FF9800,#FFB74D);border-radius:40rpx;font-size:28rpx;color:#fff;font-weight:600}
.disclaimer{text-align:center;font-size:22rpx;color:#999;padding:20rpx 40rpx 60rpx}
