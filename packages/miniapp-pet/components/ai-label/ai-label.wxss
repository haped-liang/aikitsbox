.ai-label-banner{display:flex;align-items:center;justify-content:center;padding:16rpx 24rpx;background:linear-gradient(135deg,#F5F0FF 0%,#EDE4FF 100%);border-radius:12rpx;margin:16rpx 0;gap:12rpx}
.ai-label-banner.top{margin-top:0;border-radius:0 0 12rpx 12rpx}
.ai-label-banner.bottom{margin-bottom:0;border-radius:12rpx 12rpx 0 0}
.ai-label-icon{font-size:28rpx}
.ai-label-text{font-size:24rpx;color:#7C6BA0}
.ai-label-badge{display:inline-flex;align-items:center;background:rgba(124,107,160,.12);border:1rpx solid rgba(124,107,160,.2);border-radius:6rpx;padding:4rpx 12rpx}
.badge-text{font-size:20rpx;color:#7C6BA0}
.ai-label-inline{padding:8rpx 0}.inline-text{font-size:22rpx;color:#999}
