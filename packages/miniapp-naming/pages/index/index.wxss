/* 首页样式 */

.hero-section {
  text-align: center;
  padding: 40rpx 0 30rpx;
}

.hero-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.quota-badge {
  display: inline-block;
  background: rgba(255, 107, 53, 0.1);
  color: #FF6B35;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  margin-top: 20rpx;
}

.quota-badge.quota-empty {
  background: rgba(255, 77, 79, 0.1);
  color: #FF4D4F;
}

.quota-num {
  font-weight: 700;
  font-size: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C1810;
  margin-bottom: 24rpx;
}

/* 类型选择 */
.type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-item {
  flex: 0 0 calc(50% - 8rpx);
  text-align: center;
  padding: 24rpx;
  background: #FFF8F5;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.type-item.type-active {
  background: linear-gradient(135deg, #FFF0E8 0%, #FFE4D6 100%);
  border-color: #FF6B35;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.15);
}

.type-name {
  font-size: 28rpx;
  font-weight: 500;
}

/* 表单 */
.form-section {
  margin-top: 24rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C1810;
  margin-bottom: 16rpx;
}

.required {
  color: #FF4D4F;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #FFF8F5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.form-input:focus {
  border-color: #FF6B35;
  background: #FFFFFF;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  background: #FFF8F5;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.form-textarea:focus {
  border-color: #FF6B35;
  background: #FFFFFF;
}

.form-hint {
  font-size: 22rpx;
  color: #BFBFBF;
  margin-top: 10rpx;
}

/* 选项行 */
.option-row {
  display: flex;
  gap: 16rpx;
}

.option-item {
  padding: 14rpx 28rpx;
  background: #FFF8F5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #8B7355;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.option-item.option-active {
  background: rgba(255, 107, 53, 0.1);
  color: #FF6B35;
  border-color: #FF6B35;
  font-weight: 600;
}

/* 热门标签 */
.hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

/* 开始按钮区 */
.action-section {
  padding: 40rpx 0 60rpx;
  text-align: center;
}

.btn-start {
  width: 100%;
  height: 96rpx;
  font-size: 34rpx;
  line-height: 96rpx;
}

.action-hint {
  font-size: 24rpx;
  color: #BFBFBF;
  margin-top: 20rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.modal-content {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 30rpx;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 30rpx;
  color: #2C1810;
}

.modal-option {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #FFF8F5;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.modal-option.gold {
  background: linear-gradient(135deg, #FFFBF0 0%, #FFF8E0 100%);
  border: 2rpx solid #D4A843;
}

.option-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.option-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C1810;
  margin-bottom: 6rpx;
}

.option-desc {
  font-size: 24rpx;
  color: #8B7355;
}

.modal-divider {
  text-align: center;
  font-size: 24rpx;
  color: #BFBFBF;
  margin: 10rpx 0;
}

.modal-close {
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #BFBFBF;
  margin-top: 10rpx;
}
