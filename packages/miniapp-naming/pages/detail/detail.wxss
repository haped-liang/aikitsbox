.detail-hero { text-align: center; padding: 60rpx 0 40rpx; }
.detail-name { font-size: 64rpx; font-weight: 700; color: #2C1810; letter-spacing: 12rpx; margin-bottom: 16rpx; }
.detail-score { font-size: 28rpx; color: #8B7355; margin-bottom: 20rpx; }
.big-score { font-size: 48rpx; font-weight: 700; color: #FF6B35; }
.detail-meaning { font-size: 30rpx; color: #2C1810; padding: 0 40rpx; line-height: 1.6; }
.info-text { font-size: 28rpx; color: #5D4037; line-height: 1.8; }
.lock-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.vip-tag { background: linear-gradient(135deg, #D4A843, #E8C97A); color: #fff; padding: 6rpx 16rpx; border-radius: 8rpx; font-size: 22rpx; font-weight: 600; }
.locked-preview { margin-bottom: 24rpx; }
.preview-item { padding: 12rpx 0; font-size: 26rpx; color: #8B7355; }
.unlock-btn { width: 100%; height: 80rpx; line-height: 80rpx; text-align: center; margin-top: 10rpx; }
.share-btn { width: 100%; height: 88rpx; line-height: 88rpx; text-align: center; margin: 30rpx 0 60rpx; }
