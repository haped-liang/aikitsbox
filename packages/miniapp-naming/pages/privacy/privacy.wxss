.container{padding:30rpx;font-size:28rpx;color:#333;line-height:1.8}
.policy-header{text-align:center;padding:40rpx 0 30rpx;border-bottom:1rpx solid #eee;margin-bottom:30rpx}
.policy-title{font-size:40rpx;font-weight:700;color:#2C1810;margin-bottom:12rpx}
.policy-meta{font-size:24rpx;color:#999}
.policy-section{margin-bottom:30rpx}
.section-title{font-size:30rpx;font-weight:600;color:#2C1810;margin-bottom:16rpx}
.section-text{color:#555;line-height:2}
.list-item{padding-left:20rpx;margin:4rpx 0}
.policy-footer{text-align:center;padding:40rpx 0;border-top:1rpx solid #eee;margin-top:40rpx}
.footer-text{font-size:24rpx;color:#999;margin:6rpx 0}
