<view class="container">
  <view class="title">📸 修复相册</view>
  <view wx:if="{{records.length===0}}" class="empty">
    <view class="empty-icon">🖼️</view>
    <view class="empty-text">还没有修复记录</view>
    <view class="empty-hint">去修复第一张老照片吧</view>
  </view>
  <view wx:else class="grid">
    <view wx:for="{{records}}" wx:key="id" class="item">
      <image src="{{item.after}}" mode="aspectFill"/>
      <view class="item-date">{{item.date}}</view>
    </view>
  </view>
</view>
