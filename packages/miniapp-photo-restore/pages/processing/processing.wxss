.container{background:#1A1A1A;min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:40rpx 30rpx}
.photo-preview{width:360rpx;height:360rpx;border-radius:20rpx;overflow:hidden;position:relative;margin-bottom:40rpx;border:3rpx solid rgba(255,255,255,.2)}
.photo{width:100%;height:100%}
.photo-overlay{position:absolute;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.3)}.photo-overlay.done{background:rgba(76,175,80,.3)}
.overlay-scan{position:absolute;top:0;left:0;right:0;height:4rpx;background:linear-gradient(90deg,transparent,rgba(255,255,255,.8),transparent);animation:scan 1.5s ease-in-out infinite}
@keyframes scan{0%{top:0}100%{top:100%}}
.progress-section{width:100%;display:flex;align-items:center;gap:20rpx;margin-bottom:40rpx}
.progress-bar{flex:1;height:8rpx;background:rgba(255,255,255,.15);border-radius:4rpx;overflow:hidden}
.progress-fill{height:100%;background:linear-gradient(90deg,#FFB300,#FF8F00);border-radius:4rpx;transition:width .3s}
.progress-text{font-size:28rpx;font-weight:600;color:#FFB300;width:70rpx;text-align:right}
.step-display{text-align:center;margin-bottom:40rpx}
.step-icon{font-size:56rpx;margin-bottom:16rpx}
.step-text{font-size:32rpx;font-weight:600;color:#FFF;margin-bottom:8rpx}
.step-detail{font-size:24rpx;color:rgba(255,255,255,.5)}
.tip-text{font-size:26rpx;color:rgba(255,255,255,.35);text-align:center;font-style:italic}
.done-section{margin-top:30rpx;text-align:center}
.btn-view{background:linear-gradient(135deg,#4CAF50,#66BB6A);color:#fff;border-radius:40rpx;padding:24rpx 60rpx;font-size:32rpx;font-weight:600;border:none}
