.container{background:#1A1A1A;min-height:100vh;color:#fff;padding-bottom:40rpx}
.compare-container{position:relative;width:100%;height:600rpx;overflow:hidden;background:#000}
.compare-img{width:100%;height:100%;position:absolute;top:0;left:0}
.after-img{z-index:1}
.before-clip{position:absolute;top:0;left:0;height:100%;z-index:2;overflow:hidden;border-right:3rpx solid #FFF}
.before-img{width:750rpx;height:100%}
.before-label{position:absolute;top:20rpx;left:20rpx;background:rgba(0,0,0,.7);color:#FFF;padding:6rpx 16rpx;border-radius:8rpx;font-size:22rpx;z-index:3}
.after-label{position:absolute;top:20rpx;right:20rpx;background:rgba(76,175,80,.9);color:#FFF;padding:6rpx 16rpx;border-radius:8rpx;font-size:22rpx;z-index:3}
.slider-handle{position:absolute;top:0;height:100%;z-index:4;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;justify-content:center}
.handle-line{width:3rpx;height:100%;background:#FFF;box-shadow:0 0 8rpx rgba(0,0,0,.5)}
.handle-btn{width:56rpx;height:56rpx;background:#FFF;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:24rpx;color:#333;box-shadow:0 4rpx 16rpx rgba(0,0,0,.4);position:absolute}
.slider-control{padding:20rpx 30rpx;text-align:center}
.slider-control text{font-size:24rpx;color:#999}
.actions{padding:0 24rpx}
.btn-download{width:100%;background:linear-gradient(135deg,#FFB300,#FF8F00);border-radius:16rpx;padding:28rpx;text-align:center;border:none;margin-bottom:20rpx}
.btn-main-text{font-size:32rpx;font-weight:700;color:#3E2723}
.btn-sub-text{font-size:22rpx;color:rgba(62,39,35,.7);margin-top:4rpx}
.action-row{display:flex;gap:16rpx}
.btn-secondary,.btn-primary{flex:1;height:80rpx;line-height:80rpx;border-radius:40rpx;font-size:26rpx;text-align:center}
.btn-secondary{background:rgba(255,255,255,.1);color:#FFF;border:1rpx solid rgba(255,255,255,.2)}
.btn-primary{background:#FFF;color:#3E2723;font-weight:600}
.emotional-text{text-align:center;font-size:26rpx;color:rgba(255,255,255,.5);line-height:1.8;padding:40rpx 30rpx}
